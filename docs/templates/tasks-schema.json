{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tasks",
  "description": "Micro-task list generated from an annotated design.md by /split",
  "type": "object",
  "required": ["design", "tasks"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version (omitted or '1' for v1, '2' for v2)",
      "default": "2"
    },
    "design": {
      "type": "string",
      "description": "Path to the source design document"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "When this task list was generated"
    },
    "plan_version": {
      "type": "integer",
      "description": "Incremented on each re-split",
      "default": 1
    },
    "plan_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" },
          "design_path": { "type": "string" },
          "annotation_count": { "type": "integer" }
        }
      },
      "description": "History of plan versions from re-splits"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "scope", "status", "files", "verification"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^T[0-9]{3}$",
            "description": "Task ID (T001, T002, ...)"
          },
          "title": {
            "type": "string",
            "description": "Brief imperative description"
          },
          "description": {
            "type": "string",
            "description": "Detailed task specification"
          },
          "scope": {
            "type": "string",
            "enum": ["S", "M", "L"],
            "description": "S=small (<30min), M=medium (30-90min), L=large (break down further)"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "blocked", "skipped"],
            "description": "Current task status"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^T[0-9]{3}$"
            },
            "description": "Task IDs that must complete before this task"
          },
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Files this task will create or modify"
          },
          "verification": {
            "type": "object",
            "required": ["command", "expected"],
            "properties": {
              "command": {
                "type": "string",
                "description": "Command to verify task completion"
              },
              "expected": {
                "type": "string",
                "description": "Expected output or behavior"
              }
            }
          },
          "annotations": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Human annotations from design.md relevant to this task"
          },
          "commit_sha": {
            "type": "string",
            "description": "Git commit SHA after task completion"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "description": "When this task was completed"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "When this task was started (set by select_next)"
          },
          "duration_seconds": {
            "type": "number",
            "description": "Time spent on this task in seconds"
          },
          "estimated_minutes": {
            "type": "number",
            "description": "Estimated minutes based on scope (S=15, M=60, L=120)"
          },
          "attempt_count": {
            "type": "integer",
            "description": "Number of completion attempts",
            "default": 0
          },
          "retry_history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "attempt": { "type": "integer" },
                "timestamp": { "type": "string", "format": "date-time" },
                "outcome": {
                  "type": "string",
                  "enum": ["success", "failure", "2pass_limit"]
                },
                "error_summary": { "type": "string" }
              }
            },
            "description": "History of task attempts"
          },
          "failure_reason": {
            "type": "string",
            "description": "Reason for task failure"
          },
          "tests_written": {
            "type": "integer",
            "description": "Number of tests written for this task"
          },
          "tests_passed": {
            "type": "integer",
            "description": "Number of tests passing for this task"
          },
          "cove_findings": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Chain of Verification findings"
          }
        }
      }
    }
  }
}
